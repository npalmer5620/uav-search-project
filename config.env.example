# Copy this file to config.env and adjust for your machine.
# config.env is gitignored — do not commit it.

# Path to your PX4-Autopilot source directory
PX4_DIR=~/PX4-Autopilot

# Gazebo render engine: "ogre2" (default) or "ogre" (fallback)
PX4_GZ_SIM_RENDER_ENGINE=ogre2

# PX4 SITL model target
PX4_SIM_MODEL=gz_x500_depth

# Gazebo world name (e.g. "default", "baylands", "search_area")
# "search_area" includes people and vehicles for YOLO detection
PX4_GZ_WORLD=default

# Camera render rate in Hz
CAMERA_RATE=30

# Set to 1 to suppress the Gazebo GUI (recommended in Docker)
HEADLESS=

# Set to 1 to launch foxglove_bridge alongside the sim
ENABLE_FOXGLOVE=1

# Set to 1 to start a PX4 MAVLink UDP stream for MAVSDK controllers
ENABLE_MAVSDK_MAVLINK=1
MAVSDK_MAVLINK_TARGET=planning
MAVSDK_MAVLINK_LOCAL_PORT=14541
MAVSDK_MAVLINK_REMOTE_PORT=14540

# WebSocket port exposed by foxglove_bridge
FOXGLOVE_PORT=8765

# Set to 1 to publish /uav/pose, /tf, and /uav/drone_marker from PX4 odometry
ENABLE_POSE_BRIDGE=1

# YOLO detection container settings
DETECTION_MODEL_PATH=/root/.cache/yolo/yolo11n.onnx
DETECTION_CONFIDENCE=0.4
DETECTION_DEVICE=cpu
DETECTION_PUBLISH_VIZ=true
DETECTION_IMGSZ=640
DETECTION_FRAME_SKIP=0

# Planning policy
SEARCH_POLICY=grid
MAVSDK_SYSTEM_ADDRESS=udpin://0.0.0.0:14540
RL_MODEL_PATH=artifacts/rl/search_policy/model.zip
RL_VECNORMALIZE_PATH=artifacts/rl/search_policy/vecnormalize.pkl
RL_DECISION_PERIOD_S=0.5
RL_MAX_STEP_XY_M=4.0
RL_COVERAGE_GRID_SIDE=16

# Set to 1 to disable PX4's optional Gazebo GstCameraSystem plugin
# Useful when you only need Gazebo->ROS image transport and want quieter headless logs.
DISABLE_GST_CAMERA_SYSTEM=0
